generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id            String         @id @default(cuid())
  fullName      String
  email         String         @unique
  phone         String?
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
  payments      Payment[]
  messages      Message[]
  reviews       Review[]
}

model Trip {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String
  destinations  String
  duration      String
  departureDate DateTime
  returnDate    DateTime
  groupSize     String?
  pricePerPerson Float
  singleSupplement Float?
  inclusions    String?
  exclusions    String?
  heroImage     String?
  galleryImages String[]
  pdfUrl        String?
  published     Boolean        @default(false)
  featured      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
}

enum RegistrationStatus {
  PENDING
  DEPOSIT_PAID
  FULLY_PAID
  CANCELLED
}

model Registration {
  id              String             @id @default(cuid())
  client          Client             @relation(fields: [clientId], references: [id])
  clientId        String
  trip            Trip               @relation(fields: [tripId], references: [id])
  tripId          String
  passportNumber  String
  passportCountry String
  passportIssued  DateTime
  passportExpiry  DateTime
  passportIssuedBy String
  paymentMethod   String             // "check" | "credit_card" | "ach"
  status          RegistrationStatus @default(PENDING)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  payments        Payment[]

  @@unique([clientId, tripId])
}

enum PaymentType {
  DEPOSIT
  FINAL
  REFUND
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  client          Client        @relation(fields: [clientId], references: [id])
  clientId        String
  registration    Registration  @relation(fields: [registrationId], references: [id])
  registrationId  String
  amount          Float
  processingFee   Float         @default(0)
  type            PaymentType
  status          PaymentStatus @default(PENDING)
  method          String        // "credit_card" | "ach" | "check"
  squarePaymentId String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  name      String
  content   String
  rating    Int      @default(5)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}
